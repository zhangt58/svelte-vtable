{
  "name": "@zhangt58/svelte-vtable",
  "version": "0.3.0",
  "description": "A Svelte 5 library for virtualized data tables with sorting, selection, and pagination controls.",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "svelte": "./dist/index.js",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "svelte": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./controls": {
      "svelte": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./flowbite": {
      "svelte": "./dist/index.flowbite.js",
      "types": "./dist/index.flowbite.d.ts",
      "import": "./dist/index.flowbite.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "build:styles": "node ./scripts/build-styles.cjs",
    "build": "svelte-package -i src/lib",
    "prepare": "npm run build:styles && npm run build",
    "prepublishOnly": "npm run build && npm run check && npm run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "svelte",
    "svelte5",
    "table",
    "virtual",
    "data-table",
    "sortable",
    "pagination",
    "virtualized"
  ],
  "author": "zhangt58",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zhangt58/svelte-vtable"
  },
  "bugs": {
    "url": "https://github.com/zhangt58/svelte-vtable/issues"
  },
  "homepage": "https://github.com/zhangt58/svelte-vtable#readme",
  "peerDependencies": {
    "svelte": "^5.43.5",
    "svelte-virtuallists": "^1.4.2",
    "tailwindcss": "^4.1.17"
  },
  "optionalPeerDependencies": {
    "flowbite-svelte": "^1.28.1",
    "flowbite-svelte-icons": "^3.0.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "flowbite-svelte": "^1.28.1",
    "flowbite-svelte-icons": "^3.0.0",
    "prettier": "^3.7.4",
    "prettier-plugin-svelte": "^3.4.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.3.4",
    "svelte-virtuallists": "^1.4.2",
    "vite": "^7.2.2",
    "vitest": "^2.1.9"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
